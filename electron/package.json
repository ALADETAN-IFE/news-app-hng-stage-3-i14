{
  "name": "newsroom-desktop",
  "version": "1.0.0",
  "description": "Desktop application for NEWSROOM",
  "author": "ifecodes",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.ifecodes.newsroom",
    "productName": "NEWSROOM",
    "directories": { "output": "dist-electron" },
    "files": [
      "main.js",
      {
        "from": "../dist",
        "to": "dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "certificateFile": null,
      "certificatePassword": null,
      "sign": null,
      "signingHashAlgorithms": null
  }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}